# Normalize line endings to LF everywhere that matters.
# Stops the CRLF-replacement warnings on Windows commits and keeps the
# soa-validate.lock + must-map-consumed JSON byte shape stable across
# contributor platforms. Matches the sibling soa-harness-specification
# repo's .gitattributes (same file, same rules — siblings should agree).

* text=auto eol=lf

# JSON — exact byte shape matters for the soa-validate.lock digest
# comparison and any JCS canonicalization the validator does.
*.json                text eol=lf
*.jws                 text eol=lf
*.md                  text eol=lf
*.py                  text eol=lf
*.mjs                 text eol=lf
*.js                  text eol=lf
*.go                  text eol=lf
*.yaml                text eol=lf
*.yml                 text eol=lf
*.toml                text eol=lf
*.sum                 text eol=lf
*.mod                 text eol=lf

# Shell scripts on Linux / macOS must be LF.
*.sh                  text eol=lf
*.bash                text eol=lf

# Binary — don't touch.
*.png                 binary
*.jpg                 binary
*.jpeg                binary
*.gif                 binary
*.pdf                 binary
*.zip                 binary
*.tar                 binary
*.gz                  binary
*.tgz                 binary
*.ico                 binary
