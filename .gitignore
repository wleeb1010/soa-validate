# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# Validator outputs (CI emits these to disk; never committed).
# Any `*-gate*.json` or `*-gate*.junit.xml` at repo root is a run artifact —
# named variants like adapter-gate.json, phase0d-gate.json, rc2-native-gate.json,
# gate3-mem0.json get produced during development-time regression sweeps.
/release-gate.json
/release-gate.junit.xml
/*-gate*.json
/*-gate*.junit.xml
/phase*.json
/phase*.junit.xml
/gate*.json
/gate*.junit.xml
/rc*.json
/rc*.junit.xml
/native-*.json
/native-*.junit.xml
/pin-final.json
/pin-final.junit.xml
/adapter-demo.log
/rc*.log

# CodeGraphContext local config (per-checkout, never committed)
.cgcignore

# Per-session local state (Claude Code)
.claude/


# Ephemeral session files written by impl subprocesses during test runs
sessions/

# graphify
graphify-out/cache/
graphify-out/.needs-semantic-update

